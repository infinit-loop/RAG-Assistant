# ----------------------------------------------------------------------------
# Copy this file to ".env" and adjust as needed:  cp .env.example .env
# docker-compose reads .env automatically (both for ${...} substitution and via
# the `env_file:` directive that injects these into the containers).
# ----------------------------------------------------------------------------

# --- Logging ---
# INFO shows the agent's decisions (route, mode);
LOG_LEVEL=INFO

# --- Document corpus location (inside the container) ---
# Base corpus indexed at startup. docs/examples/ holds upload-test samples and
# is intentionally NOT indexed.
DOCS_DIR=/app/docs/base_corpus

# --- Retrieval / guardrail thresholds ---
TOP_K=3
MIN_RETRIEVAL_SCORE=0.08
CONFIDENT_SCORE=0.18
AMBIGUITY_MIN_WORDS=4

# --- Backend access gate (optional) ---
# Leave empty to disable. If set, callers must send header  x-api-key: <value>
API_KEY=

# --- LLM generation ---
# Pick the provider with LLM_PROVIDER; switching it picks the right base URL,
# key and default model:
#   openrouter -> free/cheap models. Free tier is capped per day; slugs also
#                 change over time (HTTP 404 -> pick a current one from
#                 https://openrouter.ai/models?max_price=0)
#   openai     -> OpenAI API. Key: https://platform.openai.com/api-keys
#   cloudflare -> Cloudflare Workers AI (free daily allocation)
#   gemini     -> Google Gemini (free tier). Key: https://aistudio.google.com/app/apikey
LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cloudflare Workers AI needs BOTH a token and your account id (it goes in the
# URL). Token: https://dash.cloudflare.com/profile/api-tokens (Workers AI: Read).
# Models: https://developers.cloudflare.com/workers-ai/models/
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_MODEL=@cf/qwen/qwen2.5-coder-32b-instruct

# Google Gemini via its OpenAI-compatible endpoint.
# Key: https://aistudio.google.com/app/apikey  Models: gemini-2.0-flash, gemini-1.5-flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional global overrides (win over the provider defaults above):
# LLM_API_KEY=    generic fallback key
# LLM_BASE_URL=   custom OpenAI-compatible endpoint
# LLM_MODEL=      force one model regardless of provider
LLM_TIMEOUT=30
